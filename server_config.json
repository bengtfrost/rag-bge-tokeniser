{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/bfrost/ai-docs",
        "/home/bfrost/.code"
      ],
      "tool_timeout": 7200,
      "init_timeout": 60
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "rag": {
      "command": "/home/bfrost/.config/mcp-cli/rag-bge-tokeniser/.venv/bin/python",
      "args": [
        "/home/bfrost/.config/mcp-cli/rag-bge-tokeniser/rag_server.py"
      ],
      "tool_timeout": 7200,
      "init_timeout": 60
    },
    "sqlite": {
      "command": "uvx",
      "args": [
        "mcp-server-sqlite",
        "--db-path",
        "/home/bfrost/.local/share/rag-bge-tokeniser/vectors.db"
      ]
    }
  }
}
